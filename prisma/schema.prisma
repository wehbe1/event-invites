generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GuestStatus {
  pending
  confirmed
  declined
  gift_only
}

enum InvitationChannel {
  sms
  whatsapp
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firebaseUid  String?  @unique
  passwordHash String?
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  events       Event[]
}

model Event {
  id            String   @id @default(cuid())
  userId        String
  title         String
  date          DateTime
  time          String
  location      String
  locationName  String?
  address       String?
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?
  wazeUrl       String?
  description   String?
  organizerName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests Guest[]

  @@index([userId])
  @@index([date])
}

model Guest {
  id          String      @id @default(cuid())
  eventId     String
  fullName    String
  phoneNumber String
  status      GuestStatus @default(pending)
  giftAmount  Decimal     @default(0) @db.Decimal(10, 2)
  notes       String?
  inviteToken String      @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitationLogs InvitationLog[]

  @@index([eventId])
  @@index([status])
}

model InvitationLog {
  id      String            @id @default(cuid())
  guestId String
  channel InvitationChannel
  sentAt  DateTime          @default(now())
  status  String

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([sentAt])
}
